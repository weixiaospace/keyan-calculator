{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "算码工具",
  "version": "0.2.0",
  "identifier": "cn.com.dachengzhihui.calculator",
  "build": {
    "beforeDevCommand": "pnpm run dev:vite",
    "devUrl": "http://localhost:1421",
    "beforeBuildCommand": "pnpm run build:vite",
    "frontendDist": "../out"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "算码工具",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": true,
        "resizable": true,
        "center": true,
        "devtools": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://cnb.cool/dachengzhihui/keyan-calculator/-/git/raw/main/.updater/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDgxNEI3MTc0MTU1N0M4MzkKUldRNXlGY1ZkSEZMZ2JYTC9QQzJ5ZzVxdVR6RVU1Q0ExbmlLZjc1RXBRckVhd1Y1SUN1N280T0YK",
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
