{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "算码工具",
  "version": "0.1.0",
  "identifier": "cn.com.dachengzhihui.calculator",
  "build": {
    "beforeDevCommand": "pnpm run dev:vite",
    "devUrl": "http://localhost:1421",
    "beforeBuildCommand": "pnpm run build:vite",
    "frontendDist": "../out"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "算码工具",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": true,
        "resizable": true,
        "center": true,
        "devtools": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
